# Copy this file to `.env` and replace the placeholder values you actually use.

# Optional external HTML fetching
SCRAPINGBEE_API_KEY=your_scrapingbee_key
SCRAPEDO_API_KEY=your_scrapedo_token

# Optional authenticated marketplace APIs
# Wildberries official "Feedbacks and Questions" seller token.
# Without it the URL pipeline still tries the public WB imtId endpoint, Playwright, and HTML fallbacks.
WB_FEEDBACKS_API_KEY=your_wildberries_feedbacks_token

# Optional OCR for review photos.
# Install the Tesseract engine separately and set this when tesseract.exe is not on PATH.
# Example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# REVIEW_IMAGE_OCR_LANG=eng+rus
